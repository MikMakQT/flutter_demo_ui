rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(data) {
      return isSignedIn() && request.auth.uid == data.ownerUid;
    }

    function isSharedRecipient(itemId) {
      return isSignedIn()
        && exists(
          /databases/$(database)/documents/shared_items/$(request.auth.uid + "_" + itemId)
        );
    }

    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && request.auth.uid == userId;
    }

    match /items/{itemId} {
      allow read: if isOwner(resource.data) || isSharedRecipient(itemId);
      allow create: if isSignedIn()
        && request.auth.uid == request.resource.data.ownerUid;
      allow update, delete: if isOwner(resource.data);
    }

    match /shared_items/{docId} {
      allow read: if isSignedIn()
        && request.auth.uid == resource.data.toUserUid;

      allow create, update: if isSignedIn()
        && request.auth.uid == request.resource.data.fromUserUid;

      allow delete: if isSignedIn()
        && (
          request.auth.uid == resource.data.fromUserUid
          || request.auth.uid == resource.data.toUserUid
        );
    }
  }
}
